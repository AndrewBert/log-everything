rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access their own root document (e.g. onboarding metadata)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Users can only access their own subcollection data (entries, categories)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Snapshots collection for device backups
    match /snapshots/{deviceId}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
